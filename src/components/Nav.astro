---
interface Props {
	active?: 'about' | 'skills' | 'projects' | 'contact';
}

const { active } = Astro.props;

const base = 'hover:text-neutral-900 transition-colors duration-200';
const activeClass = 'text-neutral-900';

const links = [
	{ label: 'about', href: '/#about' },
	{ label: 'skills', href: '/#skills' },
	{ label: 'projects', href: '/#projects' },
	{ label: 'contact', href: '/#contact' },
];
---

<nav class='fixed top-0 left-0 right-0 z-10 border-b border-neutral-200/70 bg-white/80 backdrop-blur-sm'>
	<div class='max-w-3xl mx-auto px-6 h-14 flex items-center justify-between'>
		<a
			href='/'
			aria-label='Juan P Echeverry — home'
			class='font-mono text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
			>jpe</a
		>
		<div class='flex gap-6 text-sm text-neutral-500'>
			{links.map(({ label, href }) => (
				<a href={href} class={active === label ? activeClass : base}>{label}</a>
			))}
		</div>
	</div>
</nav>
