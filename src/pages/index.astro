---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = [
	{
		title: 'Project One',
		description:
			'A short description of what this project does and why it matters.',
		tech: ['TypeScript', 'Node.js', 'PostgreSQL'],
		link: '#',
		status: 'coming soon',
	},
	{
		title: 'Project Two',
		description:
			'A short description of what this project does and why it matters.',
		tech: ['React', 'Go', 'Docker'],
		link: '#',
		status: 'coming soon',
	},
	{
		title: 'Project Three',
		description:
			'A short description of what this project does and why it matters.',
		tech: ['Astro', 'Tailwind', 'Cloudflare'],
		link: '#',
		status: 'coming soon',
	},
];
---

<Layout>
	<!-- Nav -->
	<nav
		class='fixed top-0 left-0 right-0 z-10 border-b border-neutral-200/70 bg-white/80 backdrop-blur-sm'
	>
		<div class='max-w-3xl mx-auto px-6 h-14 flex items-center justify-between'>
			<a
				href='#'
				class='font-mono text-sm text-neutral-400 hover:text-neutral-900 transition-colors'
				>jpe</a
			>
			<div class='flex gap-6 text-sm text-neutral-400'>
				<a href='#projects' class='hover:text-neutral-900 transition-colors'
					>projects</a
				>
				<a href='#about' class='hover:text-neutral-900 transition-colors'
					>about</a
				>
				<a href='#contact' class='hover:text-neutral-900 transition-colors'
					>contact</a
				>
			</div>
		</div>
	</nav>

	<main class='max-w-3xl mx-auto px-6'>
		<!-- Hero -->
		<section class='pt-40 pb-24'>
			<p class='font-mono text-sm text-neutral-400 mb-4'>hey, I'm</p>
			<h1 class='text-5xl font-bold text-neutral-900 mb-4 tracking-tight'>
				Juan P Echeverry
			</h1>
			<p class='text-xl text-neutral-500 mb-10 max-w-xl leading-relaxed'>
				Software developer. I build things for the web.
			</p>
			<div class='flex gap-3'>
				<a
					href='/github'
					target='_blank' rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
				>
					GitHub →
				</a>
				<a
					href='/linkedin'
					target='_blank' rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
				>
					LinkedIn →
				</a>
			</div>
		</section>

		<!-- Projects -->
		<section id='projects' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-400 mb-8'>projects</h2>
			<div class='grid gap-4 sm:grid-cols-2 lg:grid-cols-3'>
				{projects.map((p) => <ProjectCard {...p} />)}
			</div>
		</section>

		<!-- About -->
		<section id='about' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-400 mb-8'>about</h2>
			<p class='text-neutral-500 leading-relaxed max-w-xl'>
				I'm a software developer based in ATL, GA. I enjoy building clean, fast,
				and useful things on the web, from backend systems to user-facing
				products.
			</p>
		</section>

		<!-- Contact -->
		<section id='contact' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-400 mb-8'>contact</h2>
			<p class='text-neutral-500 text-sm mb-6'>
				Open to new opportunities and interesting projects. Feel free to reach
				out.
			</p>
			<div class='flex gap-6'>
				<a
					href='/github'
					target='_blank' rel='noopener noreferrer'
					class='text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
				>
					GitHub
				</a>
				<a
					href='/linkedin'
					target='_blank' rel='noopener noreferrer'
					class='text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
				>
					LinkedIn
				</a>
				<a
					href='mailto:jpecheverryp@gmail.com'
					class='text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
				>
					Email
				</a>
			</div>
		</section>

		<!-- Footer -->
		<footer class='py-8 border-t border-neutral-200'>
			<p class='text-xs font-mono text-neutral-400'>© 2026 Juan P Echeverry</p>
		</footer>
	</main>
</Layout>
