---
import Layout from '../layouts/Layout.astro';
import ProjectCard from '../components/ProjectCard.astro';
import { featuredProjects } from '../data/projects';
---

<Layout>
	<a
		href='#main-content'
		class='fixed top-0 left-4 z-50 px-4 py-2 bg-white text-neutral-900 border border-neutral-400 rounded text-sm font-mono -translate-y-full focus:translate-y-4 transition-transform duration-200'
	>
		Skip to main content
	</a>

	<!-- Nav -->
	<nav
		class='fixed top-0 left-0 right-0 z-10 border-b border-neutral-200/70 bg-white/80 backdrop-blur-sm'
	>
		<div class='max-w-3xl mx-auto px-6 h-14 flex items-center justify-between'>
			<a
				href='#'
				aria-label='Juan P Echeverry — home'
				class='font-mono text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
				>jpe</a
			>
			<div class='flex gap-6 text-sm text-neutral-500'>
				<a
					href='#about'
					class='hover:text-neutral-900 transition-colors duration-200'>about</a
				>
				<a
					href='#skills'
					class='hover:text-neutral-900 transition-colors duration-200'
					>skills</a
				>
				<a
					href='#projects'
					class='hover:text-neutral-900 transition-colors duration-200'
					>projects</a
				>
				<a
					href='#contact'
					class='hover:text-neutral-900 transition-colors duration-200'
					>contact</a
				>
			</div>
		</div>
	</nav>

	<main id='main-content' class='max-w-3xl mx-auto px-6'>
		<!-- Hero -->
		<section class='pt-40 pb-24'>
			<p class='font-mono text-sm text-neutral-500 mb-4'>hey, I'm</p>
			<h1 class='text-5xl font-bold text-neutral-900 mb-4 tracking-tight'>
				Juan P Echeverry
			</h1>
			<p class='text-xl text-neutral-500 mb-10 max-w-xl leading-relaxed'>
				Backend developer. Go, Postgres, and Docker
			</p>
			<div class='flex gap-3'>
				<a
					href='/github'
					target='_blank'
					rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
				>
					GitHub →
				</a>
				<a
					href='/linkedin'
					target='_blank'
					rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
				>
					LinkedIn →
				</a>
			</div>
		</section>

		<!-- About -->
		<section id='about' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-500 mb-8'>about</h2>
			<p class='text-sm text-neutral-500 leading-relaxed max-w-xl'>
				I'm Juan P, a software developer in Atlanta. I build for the web across
				the stack, and I'm drawn to the kind of code that solves a real problem
				cleanly. Go, TypeScript, Postgres, Docker. Bilingual in English and
				Spanish. If you've got an interesting problem, I'd love to hear about
				it.
			</p>
			<div class='mt-10'>
				<p class='font-mono text-xs text-neutral-500 mb-4'>certifications</p>
				<ul class='flex flex-col gap-3'>
					{
						[
							{
								name: 'Full-Stack Web Development Certificate',
								issuer: 'Georgia Tech',
								year: '2021',
							},
							{
								name: 'Web Application Deployment & Support Certificate',
								issuer: 'Western Governors University',
								year: '2025',
							},
							{
								name: 'AWS Certified Cloud Practitioner',
								issuer: 'AWS',
								year: '2024',
							},
						].map(({ name, issuer, year }) => (
							<li class='flex items-start justify-between gap-4 max-w-xl'>
								<div>
									<p class='text-sm text-neutral-500'>{name}</p>
									<p class='text-xs text-neutral-500 mt-0.5'>{issuer}</p>
								</div>
								<span class='font-mono text-xs text-neutral-500 shrink-0 pt-0.5'>
									{year}
								</span>
							</li>
						))
					}
				</ul>
			</div>
		</section>

		<!-- Skills -->
		<section id='skills' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-500 mb-8'>skills</h2>
			<div class='flex flex-col gap-4'>
				{
					[
						{ category: 'Languages', items: ['Go', 'TypeScript'] },
						{ category: 'Frontend', items: ['Astro', 'TailwindCSS', 'HTMX'] },
						{
							category: 'Backend',
							items: ['Node', 'PostgreSQL', 'MySQL', 'SQLite', 'Docker'],
						},
						{ category: 'Cloud', items: ['Azure', 'AWS', 'Digital Ocean'] },
						{ category: 'Tools', items: ['Git', 'Linux'] },
					].map(({ category, items }) => (
						<div class='flex items-start gap-6'>
							<span class='font-mono text-xs text-neutral-500 w-24 shrink-0 pt-1'>
								{category}
							</span>
							<div class='flex flex-wrap gap-2'>
								{items.map((item) => (
									<span class='text-xs font-mono bg-neutral-100 text-neutral-600 px-2 py-1 rounded'>
										{item}
									</span>
								))}
							</div>
						</div>
					))
				}
			</div>
		</section>

		<!-- Projects -->
		<section id='projects' class='py-16 border-t border-neutral-200'>
			<div class='flex items-baseline justify-between mb-8'>
				<h2 class='font-mono text-sm text-neutral-500'>projects</h2>
				<a
					href='/projects'
					class='font-mono text-xs text-neutral-500 hover:text-neutral-900 transition-colors duration-200'
					>view all →</a
				>
			</div>
			<div class='flex flex-col gap-4'>
				{
					featuredProjects.map((project) => (
						<ProjectCard
							title={project.title}
							description={project.description}
							tech={project.tech}
							slug={project.slug}
							status={project.status}
						/>
					))
				}
			</div>
		</section>

		<!-- Contact -->
		<section id='contact' class='py-16 border-t border-neutral-200'>
			<h2 class='font-mono text-sm text-neutral-500 mb-8'>contact</h2>
			<p class='text-neutral-500 text-sm mb-6'>
				Open to new opportunities and interesting projects. Feel free to reach
				out.
			</p>
			<div class='flex gap-6'>
				<a
					href='/github'
					target='_blank'
					rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 transition-colors duration-200'
				>
					GitHub
				</a>
				<a
					href='/linkedin'
					target='_blank'
					rel='noopener noreferrer'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 transition-colors duration-200'
				>
					LinkedIn
				</a>
				<a
					href='mailto:jpecheverryp@gmail.com'
					class='text-sm font-mono text-neutral-500 hover:text-neutral-900 transition-colors duration-200'
				>
					Email
				</a>
			</div>
		</section>

		<!-- Footer -->
		<footer class='py-8 border-t border-neutral-200'>
			<p class='text-xs font-mono text-neutral-500'>
				© {new Date().getFullYear()} Juan P Echeverry
			</p>
		</footer>
	</main>
</Layout>
