---
import Layout from '../layouts/Layout.astro';
---

<Layout title='404 — Juan P Echeverry' description='Page not found'>
	<main class='max-w-3xl mx-auto px-6 pt-40 pb-24'>
		<p class='font-mono text-sm text-neutral-400 mb-4'>404</p>
		<h1 class='text-5xl font-bold text-neutral-900 mb-4 tracking-tight'>
			Page not found
		</h1>
		<p class='text-xl text-neutral-500 mb-10 max-w-xl leading-relaxed'>
			This page doesn't exist or was moved.
		</p>
		<a
			href='/'
			class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
		>
			← Go home
		</a>
	</main>
</Layout>
