---
import Layout from '../../layouts/Layout.astro';
import { projects } from '../../data/projects';
import type { Project } from '../../data/projects';

export function getStaticPaths() {
	return projects.map((project) => ({
		params: { slug: project.slug },
		props: { project },
	}));
}

interface Props {
	project: Project;
}

const { project } = Astro.props;
const paragraphs = project.longDescription.split('\n\n').filter(Boolean);
---

<Layout
	title={`${project.title} — Juan P Echeverry`}
	description={project.description}
>
	<a
		href='#main-content'
		class='fixed top-0 left-4 z-50 px-4 py-2 bg-white text-neutral-900 border border-neutral-400 rounded text-sm font-mono -translate-y-full focus:translate-y-4 transition-transform duration-200'
	>
		Skip to main content
	</a>

	<!-- Nav -->
	<nav
		class='fixed top-0 left-0 right-0 z-10 border-b border-neutral-200/70 bg-white/80 backdrop-blur-sm'
	>
		<div class='max-w-3xl mx-auto px-6 h-14 flex items-center justify-between'>
			<a
				href='/'
				aria-label='Juan P Echeverry — home'
				class='font-mono text-sm text-neutral-500 hover:text-neutral-900 transition-colors'
				>jpe</a
			>
			<div class='flex gap-6 text-sm text-neutral-500'>
				<a href='/#about' class='hover:text-neutral-900 transition-colors duration-200'
					>about</a
				>
				<a href='/#skills' class='hover:text-neutral-900 transition-colors duration-200'
					>skills</a
				>
				<a href='/#projects' class='hover:text-neutral-900 transition-colors duration-200'
					>projects</a
				>
				<a href='/#contact' class='hover:text-neutral-900 transition-colors duration-200'
					>contact</a
				>
			</div>
		</div>
	</nav>

	<main id='main-content' class='max-w-3xl mx-auto px-6 pt-32 pb-24'>
		<!-- Back link -->
		<a
			href='/projects'
			class='font-mono text-xs text-neutral-500 hover:text-neutral-900 transition-colors mb-10 inline-block'
			>← projects</a
		>

		<!-- Header -->
		<div class='mb-10'>
			<div class='flex items-baseline gap-3 mb-3'>
				<h1 class='text-3xl font-bold text-neutral-900 tracking-tight'>
					{project.title}
				</h1>
				{
					project.status && (
						<span class='font-mono text-xs text-neutral-500'>
							{project.status}
						</span>
					)
				}
			</div>
			<p class='text-neutral-500 leading-relaxed max-w-xl'>
				{project.description}
			</p>
		</div>

		<!-- Links -->
		{
			(project.liveUrl || project.githubUrl) && (
				<div class='flex gap-3 mb-12'>
					{project.liveUrl && (
						<a
							href={project.liveUrl}
							target='_blank'
							rel='noopener noreferrer'
							class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
						>
							Live →
						</a>
					)}
					{project.githubUrl && (
						<a
							href={project.githubUrl}
							target='_blank'
							rel='noopener noreferrer'
							class='text-sm font-mono text-neutral-500 hover:text-neutral-900 border border-neutral-200 hover:border-neutral-400 px-4 py-2 rounded transition-colors duration-200'
						>
							GitHub →
						</a>
					)}
				</div>
			)
		}

		<!-- Images -->
		{
			project.images.length > 0 && (
				<div class='flex flex-col gap-4 mb-12'>
					{project.images.map((src) => (
						<img
							src={src}
							alt={`${project.title} screenshot`}
							class='rounded-lg border border-neutral-200 w-full'
						/>
					))}
				</div>
			)
		}

		<!-- Long description -->
		<div class='border-t border-neutral-200 pt-10'>
			<div
				class='flex flex-col gap-4 text-neutral-500 leading-relaxed max-w-xl'
			>
				{paragraphs.map((p) => <p>{p}</p>)}
			</div>
		</div>

		<!-- Tech stack -->
		<div class='mt-10'>
			<p class='font-mono text-xs text-neutral-500 mb-3'>stack</p>
			<div class='flex flex-wrap gap-2'>
				{
					project.tech.map((t) => (
						<span class='text-xs font-mono bg-neutral-100 text-neutral-600 px-2 py-1 rounded'>
							{t}
						</span>
					))
				}
			</div>
		</div>
	</main>

	<footer class='max-w-3xl mx-auto px-6 py-8 border-t border-neutral-200'>
		<p class='text-xs font-mono text-neutral-500'>
			© {new Date().getFullYear()} Juan P Echeverry
		</p>
	</footer>
</Layout>
